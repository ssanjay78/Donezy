<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Reminder scheduling uses inexact alarms on API 33+ (no special permission
         needed). SCHEDULE_EXACT_ALARM is requested only on API 31-32 (capped via
         maxSdk); on those versions it is granted by default and can be revoked by the
         user, in which case the code falls back to inexact alarms. USE_EXACT_ALARM is
         deliberately NOT declared: it is a restricted permission Google reserves for
         apps whose core purpose is alarms/clocks/calendars, and declaring it on a
         habit tracker risks a policy rejection. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <!-- On API 33+ we rely on USE_EXACT_ALARM-free inexact scheduling plus a WorkManager
         reconciliation safety net; on 31-32 the SCHEDULE_EXACT_ALARM above applies. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Short-lived foreground service plays the reminder sound so the OS can't kill the
         process mid-playback when the app is closed. mediaPlayback type per API 34+ rules. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Lets the app ask the user to exempt it from battery optimization so Doze /
         aggressive OEM battery managers don't delay or drop reminders when closed. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Widget surfaces explicitly require this declaration to be selectable on
         the launcher's widget picker on some launchers. -->
    <queries>
        <intent>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/AppTheme"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Translucent picker shown by the reminder notification's "Snooze" action.
             excludeFromRecents + noHistory keep it from lingering in the task switcher. -->
        <activity
            android:name=".SnoozeActivity"
            android:exported="false"
            android:theme="@style/SnoozeDialogTheme"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <service
            android:name=".SoundPlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <receiver
            android:name=".ReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".StreakRescueReceiver"
            android:exported="false" />

        <!-- Boot/replace re-arms scheduled alarms. The receiver is exported because
             the system fires BOOT_COMPLETED, but the permission attribute restricts
             senders to those holding RECEIVE_BOOT_COMPLETED, satisfying Play's
             hardening guidance for exported components. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- AppWidget host requires APPWIDGET_UPDATE on the public exported path.
             Custom intra-app actions (quick-log, refresh) are sent via *explicit*
             component intents in code, so they don't need an intent-filter and
             we deliberately omit them here to limit the exported attack surface. -->
        <receiver
            android:name=".NextDueWidgetProvider"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_next_due_info" />
        </receiver>

        <receiver
            android:name=".StreakWidgetProvider"
            android:exported="true"
            android:label="@string/widget_streak_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_streak_info" />
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
