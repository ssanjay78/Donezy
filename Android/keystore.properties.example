# Copy this file to keystore.properties (which is gitignored) and fill in your
# release keystore credentials. Do NOT commit the real keystore.properties or the
# .jks file to the repo.
#
# Generate a release keystore once with:
#   keytool -genkey -v -keystore donezy-release.jks \
#           -keyalg RSA -keysize 2048 -validity 10000 -alias donezy
#
# Then enroll the upload key into Google Play App Signing — Google will hold the
# upload key and you keep the original. If you ever lose this file, Play can
# rotate the key for you, but it costs you 24-72h of downtime.

storeFile=/absolute/path/to/donezy-release.jks
storePassword=replace-me
keyAlias=donezy
keyPassword=replace-me
